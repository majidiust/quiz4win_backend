# Quiz4Win — docker-compose environment template.
# Copy to .env at the project root and fill in real values.
# docker-compose automatically reads .env from the same directory.

# ─── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# Either of the next two is accepted (publishable = new name for anon).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (used by the db-maintainer service for
# migrations and pg_dump backups).
#
# IMPORTANT — use the **Session Pooler**, not the Direct connection:
#   Supabase dashboard → Project Settings → Database → Connection string →
#   "Session pooler" (port 5432, NOT "Transaction pooler" on 6543).
#
# The Direct connection host (db.<project>.supabase.co) is IPv6-only and
# is unreachable from default Docker bridge networks. The Session Pooler
# is IPv4-reachable and fully compatible with psql + pg_dump.
#
# The username includes the project ref after a dot:
#   postgres.<project-ref>
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── db-maintainer (optional overrides) ──────────────────────────────────────
# Cron schedule for the daily backup (UTC).
BACKUP_SCHEDULE=0 2 * * *
# Run a backup immediately when the container starts.
RUN_BACKUP_ON_START=false
# Days of history to keep both on the local volume and in the S3 bucket.
BACKUP_RETENTION_DAYS=14
# Prefix under $S3_BUCKET where dumps are uploaded.
S3_BACKUP_PREFIX=backups/postgres

# ─── Optional integrations ───────────────────────────────────────────────────
GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APPLE_PAY_MERCHANT_ID=

# ─── Remitation payment gateway (MasterCard + Crypto) ────────────────────────
REMITATION_ACCESS_KEY=
REMITATION_SECRET_KEY=
# Override only if Remitation changes their base URL:
# REMITATION_BASE_URL=https://api.merchant.remitation.com/api/plugin
LIVEKIT_SERVER_URL=wss://wingobingo-gcpanf81.livekit.cloud
LIVEKIT_API_KEY=APIfWiLXNFB4JsC
LIVEKIT_API_SECRET=RDPy2nfGrJenuLSfWPPZecEapOJbB1BNzeSVjKig3UmF
LIVEKIT_WEBHOOK_SECRET=APIfWiLXNFB4JsC


# ─── Game Template Engine — Docker template-generator ────────────────────────
# Poll interval (ms) between cron-tick evaluations. Default 60000 (one minute).
# Lower values are NOT useful — cron resolution is one minute and the RPC
# de-duplicates by minute-bucket.
TEMPLATE_GEN_INTERVAL_MS=60000

# ─── Game Template Engine — LiveAvatar / HeyGen proxy (admin-liveavatar) ─────
# Provider catalog used by the admin "Game Templates → AI Presenter" tab to
# pick an avatar + voice. Leave blank to disable the picker — admins can still
# paste an avatar/voice UUID manually and AI dispatch will work as long as the
# RabbitMQ broker (below) receives the publish.
LIVEAVATAR_API_URL=https://api.liveavatar.com
LIVEAVATAR_API_KEY=35c65fd4-472f-41f0-a0b1-b84bc8c72ee4

# ─── Game Template Engine — RabbitMQ Management HTTP publisher ───────────────
# Used by admin-games "start" endpoint to publish quiz.show.start when a
# templated game with ai_enabled=true transitions to status=live. Best-effort:
# the start transition is never rolled back if publishing fails.
#
# Single AMQP connection URI with credentials embedded — the helper rewrites
# amqp(s):// to http(s):// and publishes via the RabbitMQ Management HTTP API
# on the standard 443/80 port of the same host (works with CloudAMQP,
# RabbitMQ.com, and self-hosted clusters reverse-proxied through nginx).
# Leave empty to disable publishing.
RABBITMQ_URL=amqps://<user>:<password>@<host>/<vhost>
# Optional override; if absent, the vhost is taken from the URL path.
# RABBITMQ_VHOST=
# Target exchange ("" routes to default exchange = direct-to-queue) and queue
# the AI presenter service consumes from. The default queue name matches the
# spec in docs/live-avatar-and-game-template-engine.md.
MQ_COMMAND_EXCHANGE=
MQ_COMMAND_QUEUE=quiz.show.start

# ─── Firebase Cloud Messaging (push notifications) ───────────────────────────
# Place the Firebase service-account JSON file at:
#   configs/quiz4win-68443-firebase-adminsdk-fbsvc-24d33392b8.json
# The admin container mounts ./configs as /app/configs (read-only volume).
# No extra env vars are needed — credentials are read directly from the file.

# ─── Admin panel UI strings (optional) ───────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Quiz4Win Admin
