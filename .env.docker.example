# Quiz4Win — docker-compose environment template.
# Copy to .env at the project root and fill in real values.
# docker-compose automatically reads .env from the same directory.

# ─── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# Either of the next two is accepted (publishable = new name for anon).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string (used by the db-maintainer service for
# migrations and pg_dump backups). Get it from the Supabase dashboard:
#   Project Settings → Database → Connection string → URI
# Prefer the "Session pooler" (port 5432) URL for compatibility with pg_dump.
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ─── db-maintainer (optional overrides) ──────────────────────────────────────
# Cron schedule for the daily backup (UTC).
BACKUP_SCHEDULE=0 2 * * *
# Run a backup immediately when the container starts.
RUN_BACKUP_ON_START=false
# Days of history to keep both on the local volume and in the S3 bucket.
BACKUP_RETENTION_DAYS=14
# Prefix under $S3_BUCKET where dumps are uploaded.
S3_BACKUP_PREFIX=backups/postgres

# ─── Optional integrations ───────────────────────────────────────────────────
GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APPLE_PAY_MERCHANT_ID=
LIVEKIT_SERVER_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WEBHOOK_SECRET=

# ─── Admin panel UI strings (optional) ───────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Quiz4Win Admin
